{
  "name": "ReservaOnline",
  "version": "1.0.0",
  "description": "Projeto de automacao - desafio tecnico Desbravador (Cypress + BDD)",
  "main": "cypress.config.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run --browser chrome",
    "cy:run:headed": "cypress run --headed --browser chrome",
    "test": "npm run cy:run",
    "report:merge": "npx mochawesome-merge \"cypress/results/.jsons/*.json\" > cypress/results/mochawesome.json",
    "report:generate": "npx marge cypress/results/mochawesome.json --reportDir cypress/reports/html --reportFilename index --inline",
    "report:clean": "node ./scripts/clean-reports.js",
    "test:report": "npm run report:clean && npm run cy:run && npm run report:merge && npm run report:generate"
  },
  "keywords": [],
  "author": "Diego Barros",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "cypress": "^15.13.1",
    "cypress-mochawesome-reporter": "^4.0.2",
    "esbuild": "^0.28.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": "cypress/e2e/step_definitions/**/*.js"
  }
}
